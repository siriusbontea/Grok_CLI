def get_python():
    """Determine the Python interpreter path, preferring virtual environment if available."""
    venv_python = Path(".venv/bin/python")
    return str(venv_python) if venv_python.exists() else "python3"

def run_command(cmd, bg=False):
    """
    Run a shell command, optionally in background.
    
    Args:
        cmd (str): The command to execute.
        bg (bool): If True, run in background without capturing output.
    
    Returns:
        bool: True if successful (return code 0), False otherwise.
    """
    try:
        if bg:
            subprocess.Popen(cmd, shell=True)
            console.print(f"[green]Started: {cmd}[/]")
            return True
        result = subprocess.run(cmd, shell=True, capture_output=True, text=True)
        if result.stdout: console.print(f"[dim]{result.stdout}[/]")
        if result.stderr: console.print(f"[red]{result.stderr}[/]")
        return result.returncode == 0
    except Exception as e:
        console.print(f"[red]Error: {e}[/]")
        return False

def get_context_percentage():
    """
    Estimate the percentage of context window used by the conversation history.
    
    Returns:
        tuple: (color str, percentage int) for display.
    """
    # Rough token estimation: average word length ~4 chars per token
    total_tokens = sum(len(m["content"]) for m in HISTORY) // 4
    max_context = 128000  # Assumed max tokens for the model
    percent = (total_tokens / max_context) * 100
    if percent <= 70:
        color = "green"
    elif percent <= 85:
        color = "yellow"
    else:
        color = "red"
    return color, int(percent)

def get_formatted_cwd():
    """Get the current working directory, formatted with ~ for home directory."""
    cwd = os.getcwd()
    home = os.path.expanduser("~")
    if cwd == home:
        return "~"
    elif cwd.startswith(home):
        return "~" + cwd[len(home):].replace("\\", "/")  # Use / for Unix-like display
    else:
        return cwd.replace("\\", "/")

