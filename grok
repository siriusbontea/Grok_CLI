            reply = resp.choices[0].message.content
            console.print(Markdown(reply))
            HISTORY.append({"role": "assistant", "content": reply})

            # Detect and handle multiple code blocks in AI response
            code_matches = re.findall(r"```(\w*)\n(.*?)\n```", reply, re.DOTALL)
            for i, code_match in enumerate(code_matches):
                language = code_match[0].lower()
                code = code_match[1].strip() + "\n"
                ext = EXTENSION_MAP.get(language, ".txt")

                # Extract suggested filename from user input (for first block) or default
                suggested_filename = extract_suggested_filename(user) if i == 0 else None
                if suggested_filename:
                    default = suggested_filename
                else:
                    default = f"generated_{i}{ext}"

                # Prompt to save the code
                save = Prompt.ask(f"[green]Save {language or 'file'} #{i+1}? (y/n/[filename])[/]", default="y")
                if save in {"n", "no"}:
                    continue
                path = save if save not in {"y", "yes"} else Prompt.ask("Save as", default=default)

                # Check for overwrite
                full = Path(path).resolve()
                if full.exists():
                    overwrite = Prompt.ask(f"[yellow]{full} exists. Overwrite? (y/n)[/]", default="n")
                    if overwrite.lower() != "y":
                        continue

                # Resolve and save to full path
                full.parent.mkdir(parents=True, exist_ok=True)
                full.write_text(code)
                console.print(f"[green]Saved: {full}[/]")

                # Optionally run if Python file
                if full.suffix == ".py" and Prompt.ask("[yellow]Run now?[/]", default="y") == "y":
                    os.system(f"{get_python()} {full}")

                # Optionally run tests if test suite detected
                if (Path("tests").exists() or any(p.name.startswith("test_") for p in Path(".").iterdir())):
                    if Prompt.ask("[yellow]Run tests?[/]", default="y") == "y":
                        run_command("pytest -q")

                # Optionally commit to Git if repo exists
                if Path(".git").exists() and Prompt.ask("[yellow]Git commit?[/]", default="y") == "y":
                    # Use first line of reply as commit summary (truncated and safely quoted)
                    summary = reply.split("\n")[0][:50]
                    safe_message = shlex.quote("Grok: " + summary)
                    run_command(f'git add . && git commit -m {safe_message}')

        except KeyboardInterrupt:
            break
        except Exception as e:
            console.print(f"[red]Error: {e}[/]")

# Entry point: start the chat loop
if __name__ == "__main__":
    chat()
