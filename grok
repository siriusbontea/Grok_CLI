            # Handle 'dockerize' command: generate Docker files and build image
            if user.lower() == "dockerize":
                # Basic Dockerfile content
                dockerfile = '''FROM python:3.12-slim
WORKDIR /app
COPY . .
RUN pip install -r requirements.txt
CMD ["python", "main.py"]
'''
                # Basic docker-compose.yml content
                compose = '''version: "3.8"
services:
  app:
    build: .
    ports:
      - "8000:8000"
'''
                Path("Dockerfile").write_text(dockerfile)
                Path("docker-compose.yml").write_text(compose)
                console.print("[green]Dockerfile + docker-compose.yml created[/]")
                run_command("docker build -t grok-app .")
                continue

            # Handle 'review' command: AI-based code review
            if user.lower() == "review":
                # Find all Python files in current directory and subdirs
                files = list(Path(".").rglob("*.py"))
                if not files:
                    console.print("[red]No .py files found[/]"); continue
                # Concatenate code with file headers (limit to ~30k chars)
