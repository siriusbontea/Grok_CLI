            # Handle 'requirements generate' command: basic requirements.txt generation
            if user.lower() == "requirements generate":
                # Simple scan for imports in .py files
                files = list(Path(".").rglob("*.py"))
                imports = set()
                for f in files:
                    try:
                        content = f.read_text()
                        for line in content.splitlines():
                            if line.startswith("import ") or line.startswith("from "):
                                pkg = line.split()[1].split(".")[0]
                                if pkg not in {"os", "re", "sys", "builtins"}:  # Skip stdlib
                                    imports.add(pkg)
                    except:
                        pass
                if not imports:
                    console.print("[red]No imports found[/]")
                    continue
                reqs = "\n".join(sorted(imports)) + "\n"
                Path("requirements.txt").write_text(reqs)
                console.print("[green]Generated requirements.txt[/]")
