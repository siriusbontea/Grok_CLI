def extract_suggested_filename(user_input):
    """
    Parse the user input to extract a suggested filename if mentioned (e.g., "file called README.md").
    
    Returns:
        str or None: The suggested filename if found, else None.
    """
    # Improved regex to match various phrases like "create a file called X", "populate X with", "make file Y", etc.
    patterns = [
        r"(?:create|make|generate|write|add)\s+(?:a|the)?\s+file\s+(?:called|named)?\s*([^\s\"';]+?\.\w+)",
        r"(?:populate|fill|update)\s+([^\s\"';]+?\.\w+)\s+(?:with|using)",
        r"file\s+(?:called|named)\s+([^\s\"';]+?\.\w+)"
    ]
    for pattern in patterns:
        match = re.search(pattern, user_input, re.IGNORECASE)
        if match:
            return match.group(1)
    return None

