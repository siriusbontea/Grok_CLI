class CustomCompleter(Completer):
    """Custom completer for commands and paths."""
    def __init__(self):
        self.command_completer = WordCompleter([
            'model fast', 'model best', 'preview', 'dockerize', 'review', 'debug model',
            'cd ', 'ls', 'mkdir ', 'touch ', 'rm ', 'mv ', 'cp ',
            'venv create', 'venv activate', 'pip install ', 'requirements generate',
            'git init', 'git status', 'git add ', 'git push',
            'clear', 'history', 'run ', 'test', 'help', 'quit', 'exit'
        ], ignore_case=True)
        self.path_completer = PathCompleter()

    def get_completions(self, document, complete_event):
        text = document.text_before_cursor.lower()
        if text.startswith(('cd ', 'mkdir ', 'touch ', 'rm ', 'mv ', 'cp ', 'run ', 'git add ')):
            return self.path_completer.get_completions(document, complete_event)
        else:
            return self.command_completer.get_completions(document, complete_event)

def chat():
    """Main loop for the CLI."""
    global MODEL, HISTORY
    display_startup_message()

    prompt_style = Style.from_dict({
        'percentage': 'green',
        'cwd': 'ansiblue',
        'prompt-symbol': 'ansigreen',
    })
    completer = CustomCompleter()

    while True:
        try:
            color, percent = get_context_percentage()
            ansi_color = color_map[color]
            formatted_cwd = get_formatted_cwd()
            prompt_message = [
                ('', '(@ '),
                (f'fg:{ansi_color}', f'{percent}%'),
                ('', ') '),
                ('class:cwd', f'{formatted_cwd} '),
                ('class:prompt-symbol', '❯ '),
            ]
            user = prompt(prompt_message, style=prompt_style, completer=completer)
            if user.lower() in {"quit", "exit"}: break
            if not user.strip(): continue

            # === COMMANDS ===
            if user.lower() == "help":
                table = Table(title="Grok CLI Commands")
                table.add_column("Command", style="cyan")
                table.add_column("Description")
                commands = [
                    ("model fast/best", "Switch between grok-code-fast-1 (fast) and grok-4 (best) models"),
                    ("preview", "Auto-start web server if a web app is detected"),
                    ("dockerize", "Generate Dockerfile and docker-compose.yml"),
                    ("review", "AI-based code review on Python files"),
                    ("debug model", "Show model, Python, dir, venv, git status"),
                    ("cd [path]", "Change directory (restricted to project)"),
                    ("ls", "List files"),
                    ("mkdir [dir]", "Create directory"),
                    ("touch [file]", "Create empty file"),
                    ("rm [path]", "Delete file/dir (with confirm)"),
                    ("mv [src] [dst]", "Move/rename"),
                    ("cp [src] [dst]", "Copy"),
                    ("venv create", "Create .venv"),
                    ("venv activate", "Print activation instructions"),
                    ("pip install [pkg]", "Install package"),
                    ("requirements generate", "Scan imports → requirements.txt"),
                    ("git init/status/add/push", "Git operations"),
                    ("clear", "Clear conversation history"),
                    ("history", "Show chat summary"),
                    ("run [file]", "Run Python file"),
                    ("test", "Run pytest or generate tests"),
                    ("quit/exit", "Exit"),
                    ("help", "This menu")
                ]
                for cmd, desc in commands:
                    table.add_row(cmd, desc)
                console.print(table)
                continue

            if user.lower() == "debug model":
                table = Table(title="Debug Info")
                table.add_column("Key"); table.add_column("Value")
                table.add_row("Model", MODEL)
                table.add_row("Python", str(get_python()))
                table.add_row("Dir", os.getcwd())
                table.add_row("Venv", "Yes" if Path(".venv").exists() else "No")
                table.add_row("Git", "Yes" if Path(".git").exists() else "No")
                console.print(table)
                continue

            if user.lower().startswith("cd "):
                raw_path = user.split(maxsplit=1)[1].strip() if len(user.split()) > 1 else "~"
                try:
                    expanded = Path(raw_path).expanduser()
                    new_path = (Path.cwd() / expanded).resolve()
                    if not str(new_path).startswith(INITIAL_CWD):
                        console.print("[red]Cannot navigate outside project.[/]")
                        continue
                    os.chdir(new_path)
                    console.print(f"[green]Changed to: {os.getcwd()}[/]")
                except Exception as e:
                    console.print(f"[red]Error: {e}[/]")
                continue

            if user.lower() == "ls":
                files = os.listdir(".")
                if not files:
                    console.print("[dim]Empty[/]")
                    continue
                table = Table(title="Current Directory")
                table.add_column("Type", style="cyan")
                table.add_column("Name")
                for f in sorted(files):
                    is_dir = "[blue]dir[/]" if os.path.isdir(f) else "[green]file[/]"
                    table.add_row(is_dir, f)
                console.print(table)
                continue

            if user.lower().startswith("mkdir "):
                dir_name = user.split(maxsplit=1)[1].strip()
                if not dir_name:
                    console.print("[red]Usage: mkdir [dir][/]")
                    continue
                try:
                    Path(dir_name).mkdir(parents=True, exist_ok=True)
                    console.print(f"[green]Created: {dir_name}[/]")
                except Exception as e:
                    console.print(f"[red]Error: {e}[/]")
                continue

            if user.lower().startswith("touch "):
                file_name = user.split(maxsplit=1)[1].strip()
                if not file_name:
                    console.print("[red]Usage: touch [file][/]")
                    continue
                try:
                    Path(file_name).touch(exist_ok=True)
                    console.print(f"[green]Created: {file_name}[/]")
                except Exception as e:
                    console.print(f"[red]Error: {e}[/]")
                continue

            if user.lower().startswith("rm "):
                path = user.split(maxsplit=1)[1].strip()
                if not path or not Path(path).exists():
                    console.print("[red]Path not found[/]")
                    continue
                if Prompt.ask(f"[yellow]Delete {path}? (y/n)[/]", default="n").lower() != "y":
                    continue
                try:
                    if Path(path).is_dir():
                        shutil.rmtree(path)
                    else:
                        os.remove(path)
                    console.print(f"[green]Deleted: {path}[/]")
                except Exception as e:
                    console.print(f"[red]Error: {e}[/]")
                continue

            if user.lower().startswith("mv "):
                parts = user.split(maxsplit=2)
                if len(parts) < 3:
                    console.print("[red]Usage: mv [src] [dst][/]")
                    continue
                src, dst = parts[1], parts[2]
                try:
                    shutil.move(src, dst)
                    console.print(f"[green]Moved: {src} → {dst}[/]")
                except Exception as e:
                    console.print(f"[red]Error: {e}[/]")
                continue

            if user.lower().startswith("cp "):
                parts = user.split(maxsplit=2)
                if len(parts) < 3:
                    console.print("[red]Usage: cp [src] [dst][/]")
                    continue
                src, dst = parts[1], parts[2]
                try:
                    if Path(src).is_dir():
                        shutil.copytree(src, dst)
                    else:
                        shutil.copy(src, dst)
                    console.print(f"[green]Copied: {src} → {dst}[/]")
                except Exception as e:
                    console.print(f"[red]Error: {e}[/]")
                continue

            if user.lower() == "model fast":
                MODEL = "grok-code-fast-1"
                console.print("[green]→ grok-code-fast-1[/]")
                continue
            if user.lower() == "model best":
                MODEL = "grok-4"
                console.print("[green]→ grok-4[/]")
                continue

            if user.lower() == "preview":
                if Path("main.py").exists() and "fastapi" in Path("main.py").read_text().lower():
                    run_command("uvicorn main:app --reload", bg=True)
                elif Path("app.py").exists() and "flask" in Path("app.py").read_text().lower():
                    run_command("flask run", bg=True)
                else:
                    console.print("[red]No web app detected[/]")
                continue

            if user.lower() == "dockerize":
                dockerfile = '''FROM python:3.12-slim
WORKDIR /app
COPY . .
RUN pip install -r requirements.txt
CMD ["python", "main.py"]
'''
                compose = '''version: "3.8"
services:
  app:
    build: .
    ports:
      - "8000:8000"
'''
                Path("Dockerfile").write_text(dockerfile)
                Path("docker-compose.yml").write_text(compose)
                console.print("[green]Docker files created[/]")
                run_command("docker build -t grok-app .")
                continue

            if user.lower() == "review":
                files = list(Path(".").rglob("*.py"))
                if not files:
                    console.print("[red]No .py files[/]")
                    continue
                code = "\n\n".join(f"# {f}\n{f.read_text()}" for f in files)
                HISTORY.append({"role": "user", "content": f"Review this code:\n\n{code[:30000]}"})
                with console.status("Reviewing..."):
                    resp = client.chat.completions.create(model=MODEL, messages=HISTORY, temperature=0.2)
                review = resp.choices[0].message.content
                console.print(Markdown(f"## Code Review\n{review}"))
                HISTORY.append({"role": "assistant", "content": review})
                continue

            if user.lower() == "venv create":
                if Path(".venv").exists():
                    console.print("[yellow].venv exists[/]")
                    continue
                run_command("python3 -m venv .venv")
                console.print("[green].venv created[/]")
                continue

            if user.lower() == "venv activate":
                console.print("[yellow]source .venv/bin/activate (Unix) or .venv\\Scripts\\activate (Win)[/]")
                continue

            if user.lower().startswith("pip install "):
                pkg = user.split(maxsplit=2)[2].strip() if len(user.split()) > 2 else ""
                if not pkg:
                    console.print("[red]Usage: pip install [pkg][/]")
                    continue
                run_command(f"{get_python()} -m pip install {pkg}")
                continue

            if user.lower() == "requirements generate":
                files = list(Path(".").rglob("*.py"))
                imports = set()
                for f in files:
                    try:
                        for line in f.read_text().splitlines():
                            if line.startswith(("import ", "from ")):
                                pkg = line.split()[1].split(".")[0]
                                if pkg not in {"os", "re", "sys", "builtins"}:
                                    imports.add(pkg)
                    except: pass
                if not imports:
                    console.print("[red]No imports[/]")
                    continue
                Path("requirements.txt").write_text("\n".join(sorted(imports)) + "\n")
                console.print("[green]requirements.txt generated[/]")
                continue

            if user.lower().startswith("git "):
                sub = user.lower().split(maxsplit=1)[1] if len(user.split()) > 1 else ""
                if sub == "init":
                    run_command("git init")
                elif sub == "status":
                    run_command("git status")
                elif sub.startswith("add "):
                    p = sub.split(maxsplit=1)[1] if len(sub.split()) > 1 else "."
                    run_command(f"git add {p}")
                elif sub == "push":
                    if not run_command("git remote get-url origin", bg=False):
                        remote = Prompt.ask("[yellow]Remote URL:[/]")
                        run_command(f"git remote add origin {remote}")
                    run_command("git push -u origin main")
                else:
                    console.print("[red]Supported: init, status, add [file], push[/]")
                continue

            if user.lower() == "clear":
                HISTORY = [HISTORY[0]]
                console.print("[green]History cleared[/]")
                continue

            if user.lower() == "history":
                if len(HISTORY) <= 1:
                    console.print("[dim]No history[/]")
                    continue
                table = Table(title="History")
                table.add_column("Role", style="cyan")
                table.add_column("Content")
                for msg in HISTORY[1:]:
                    c = msg["content"][:100] + "..." if len(msg["content"]) > 100 else msg["content"]
                    table.add_row(msg["role"], c)
                console.print(table)
                continue

            if user.lower().startswith("run "):
                file = user.split(maxsplit=1)[1].strip()
                if not file or not Path(file).exists() or not file.endswith(".py"):
                    console.print("[red]Usage: run [file.py][/]")
                    continue
                run_command(f"{get_python()} {file}")
                continue

            if user.lower() == "test":
                if Path("tests").exists() or any(p.name.startswith("test_") for p in Path(".").iterdir()):
                    run_command("pytest -q")
                else:
                    files = list(Path(".").rglob("*.py"))
                    if not files:
                        console.print("[red]No .py files[/]")
                        continue
                    code = "\n\n".join(f"# {f}\n{f.read_text()}" for f in files)
                    HISTORY.append({"role": "user", "content": f"Generate pytest tests:\n\n{code[:20000]}"})
                    with console.status("Generating..."):
                        resp = client.chat.completions.create(model=MODEL, messages=HISTORY, temperature=0.5)
                    tests = resp.choices[0].message.content
                    console.print(Markdown(f"## Tests\n{tests}"))
                    HISTORY.append({"role": "assistant", "content": tests})
                    if Prompt.ask("[green]Save? (y/n)[/]", default="y").lower() == "y":
                        Path("test_generated.py").write_text(tests)
                        console.print("[green]Saved: test_generated.py[/]")
                continue

            # === AI CHAT + ARTIFACTS ===
            HISTORY.append({"role": "user", "content": user})
            with console.status("[bold green]Grok thinking..."):
                resp = client.chat.completions.create(model=MODEL, messages=HISTORY, temperature=0.3, max_tokens=4096)
            reply = resp.choices[0].message.content
            console.print(Markdown(reply))
            HISTORY.append({"role": "assistant", "content": reply})

            # === CODE BLOCK + ARTIFACT HANDLING ===
            code_matches = []
            # Regular code blocks
            code_matches.extend(re.findall(r"```(\w*)\n(.*?)\n```", reply, re.DOTALL))
            # Artifact blocks: ```artifact path/to/file.py\ncontent\n```
            artifact_matches = re.findall(rf"{ARTIFACT_START}\s+([^\n]+)\n(.*?)\n{ARTIFACT_END}", reply, re.DOTALL)
            for path, content in artifact_matches:
                lang = Path(path).suffix.lstrip(".") or "text"
                code_matches.append((lang, content.strip() + "\n", path.strip()))

            for idx, match in enumerate(code_matches):
                if len(match) == 3:  # (lang, code, path) → artifact
                    language, code, target_path = match
                    save_path = Path(target_path)
                    console.print(f"[bold cyan]Artifact → {save_path}[/]")
                else:  # (lang, code) → regular
                    language, code = match
                    ext = EXTENSION_MAP.get(language, ".txt")
                    suggested = extract_suggested_filename(user) if idx == 0 else None
                    default = suggested or f"generated_{idx}{ext}"
                    save = Prompt.ask(f"[green]Save {language or 'file'} #{idx+1}? (y/n/[filename])[/]", default="y")
                    if save in {"n", "no"}: continue
                    path_input = save if save not in {"y", "yes"} else Prompt.ask("Save as", default=default)
                    save_path = Path(path_input)

                # === UNIFIED SAVE LOGIC ===
                full = save_path.resolve()
                if not str(full).startswith(INITIAL_CWD):
                    console.print(f"[red]Blocked: outside project[/]")
                    continue
                if full.exists():
                    if Prompt.ask(f"[yellow]{full} exists. Overwrite?[/]", default="n").lower() != "y":
                        continue
                full.parent.mkdir(parents=True, exist_ok=True)
                full.write_text(code)
                console.print(f"[green]Saved: {full}[/]")

                # Auto-run
                if full.suffix == ".py" and Prompt.ask("[yellow]Run now?[/]", default="y") == "y":
                    run_command(f"{get_python()} {full}")

                # Auto-test
                if (Path("tests").exists() or any(p.name.startswith("test_") for p in Path(".").iterdir())):
                    if Prompt.ask("[yellow]Run tests?[/]", default="y") == "y":
                        run_command("pytest -q")

                # Auto-commit
                if Path(".git").exists() and Prompt.ask("[yellow]Git commit?[/]", default="y") == "y":
                    summary = reply.split("\n")[0][:50]
                    safe_msg = shlex.quote("Grok: " + summary)
                    run_command(f"git add . && git commit -m {safe_msg}")

        except KeyboardInterrupt:
            break
        except Exception as e:
            console.print(f"[red]Error: {e}[/]")

if __name__ == "__main__":
    chat()
