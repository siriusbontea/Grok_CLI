class CustomCompleter(Completer):
    """Custom completer for commands and paths where appropriate."""
    def __init__(self):
        self.command_completer = WordCompleter([
            'model fast', 'model best', 'preview', 'dockerize', 'review', 'debug model',
            'cd ', 'ls', 'mkdir ', 'touch ', 'rm ', 'mv ', 'cp ',
            'venv create', 'venv activate', 'pip install ', 'requirements generate',
            'git init', 'git status', 'git add ', 'git push',
            'clear', 'history', 'run ', 'test', 'help', 'quit', 'exit'
        ], ignore_case=True)
        self.path_completer = PathCompleter()

    def get_completions(self, document, complete_event):
        text = document.text_before_cursor.lower()
        if text.startswith(('cd ', 'mkdir ', 'touch ', 'rm ', 'mv ', 'cp ', 'run ', 'git add ')):
            # Use path completer for commands that take paths
            word_before = document.get_word_before_cursor()
            return self.path_completer.get_completions(document, complete_event)
        else:
            # Use command completer otherwise
            return self.command_completer.get_completions(document, complete_event)

