                parts = user.split(maxsplit=2)
                if len(parts) < 3:
                    console.print("[red]Usage: mv [src] [dst][/]")
                    continue
                src, dst = parts[1], parts[2]
                try:
                    shutil.move(src, dst)
                    console.print(f"[green]Moved: {src} -> {dst}[/]")
                except Exception as e:
                    console.print(f"[red]Error: {e}[/]")
                continue

            # Handle 'cp' command: copy file or directory
            if user.lower().startswith("cp "):
                parts = user.split(maxsplit=2)
                if len(parts) < 3:
                    console.print("[red]Usage: cp [src] [dst][/]")
                    continue
                src, dst = parts[1], parts[2]
                try:
                    if Path(src).is_dir():
                        shutil.copytree(src, dst)
                    else:
                        shutil.copy(src, dst)
