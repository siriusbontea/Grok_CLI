                    ("ls", "List files and directories in the current directory"),
                    ("mkdir [dir]", "Create a new directory (creates parents if needed)"),
                    ("touch [file]", "Create an empty file"),
                    ("rm [path]", "Delete a file or directory (with confirmation)"),
                    ("mv [src] [dst]", "Move/rename a file or directory"),
                    ("cp [src] [dst]", "Copy a file or directory"),
                    ("venv create", "Create a virtual environment in .venv"),
                    ("venv activate", "Print instructions to activate the virtual environment"),
